# WhoDis environment configuration
# Copy to .env and fill in values. Never commit .env.

# --- PostgreSQL connection (required) -----------------------------------
# These bootstrap the database connection BEFORE encrypted config is
# accessible, so they must live in .env (not in the configuration table).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=whodis_db
POSTGRES_USER=whodis_user
POSTGRES_PASSWORD=

# --- Encryption (required) ----------------------------------------------
# Fernet key (base64-encoded 32 bytes). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CRITICAL: changing this key makes every encrypted configuration value
# unreadable. Always run scripts/export_config.py before rotating.
# Pairs with .whodis_salt (per-installation file, also gitignored).
WHODIS_ENCRYPTION_KEY=

# --- Optional flags ------------------------------------------------------
# Set to "true" in production deployments. When unset/false, the encryption
# service prints diagnostic warnings on key load.
# WHODIS_PRODUCTION=false

# Dev-only auth bypass. When set, every request authenticates as this email.
# DO NOT set in production. Cannot be enabled via DB config — env-var only.
# DANGEROUS_DEV_AUTH_BYPASS_USER=dev@example.com
