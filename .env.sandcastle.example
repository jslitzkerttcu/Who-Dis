# Who-Dis SandCastle env-var matrix (WD-CFG-05).
# These values are injected by the SandCastle portal env-var system
# (encrypted at rest with portal Fernet key) at deploy time. Do NOT commit
# real values. This file is the canonical contract — every key listed here
# must be set in the portal for the container to start cleanly.

# --- Flask runtime ------------------------------------------------------------
FLASK_ENV=production
SECRET_KEY=replace-with-random-bytes              # Flask session signing (>=32 bytes random)
GUNICORN_WORKERS=2

# --- Database (WD-CFG-02 / WD-DB-01) ------------------------------------------
# Provided by `provision-db.sh who-dis` on the SandCastle host
DATABASE_URL=postgresql://who-dis_user:CHANGEME@postgres:5432/who-dis_db

# --- Keycloak OIDC (WD-AUTH-02 / WD-AUTH-03) ----------------------------------
KEYCLOAK_ISSUER=https://auth.sandcastle.ttcu.com/realms/sandcastle
KEYCLOAK_CLIENT_ID=who-dis
KEYCLOAK_CLIENT_SECRET=CHANGEME                   # Generated by Keycloak on realm import; copy from admin console (Plan 06 checkpoint)

# --- LDAP / Active Directory --------------------------------------------------
LDAP_SERVER=ldap://dc.example.local
LDAP_BIND_DN=CN=svc_whodis,OU=Service,DC=example,DC=local
LDAP_BIND_PASSWORD=CHANGEME

# --- Microsoft Graph ----------------------------------------------------------
GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_SECRET=CHANGEME

# --- Genesys Cloud ------------------------------------------------------------
GENESYS_CLIENT_ID=00000000-0000-0000-0000-000000000000
GENESYS_CLIENT_SECRET=CHANGEME
GENESYS_REGION=mypurecloud.com
